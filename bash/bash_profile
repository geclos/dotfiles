#
# ~/.bash_profile
#

[[ -f ~/.bash_aliases ]] && . ~/.bash_aliases
[[ -f ~/.bash_env ]] && . ~/.bash_env

# if running bash
if [ -n "$BASH_VERSION" ]; then
  # include .bashrc if it exists
  if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
  fi
fi

# Open git worktrees in new tmux sessions
# gwt: create git worktree + open/switch tmux session in it
gwt() {
  local wt dir base name
  wt="$1"
  if [ -z "$wt" ]; then
    echo "usage: gwt <path-or-branch>"
    return 1
  fi
  git worktree add "$wt" || return 1
  dir="$(realpath "$wt" 2>/dev/null || printf "%s" "$wt")"
  base="$(basename "$dir")"
  # tmux-safe session name (no trailing underscores)
  name="$(printf "%s" "$base" |
    tr '[:upper:]' '[:lower:]' |
    tr -c '[:alnum:]' '_' |
    sed 's/^_//; s/_$//')"
  # fallback if name becomes empty
  [ -z "$name" ] && name="worktree"
  if tmux has-session -t "$name" 2>/dev/null; then
    tmux switch-client -t "$name" 2>/dev/null || tmux attach -t "$name"
  else
    tmux new-session -d -s "$name" -c "$dir"
    tmux switch-client -t "$name" 2>/dev/null || tmux attach -t "$name"
  fi
}
